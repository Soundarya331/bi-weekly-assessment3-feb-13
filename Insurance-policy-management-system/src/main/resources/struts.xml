<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.5//EN" "http://struts.apache.org/dtds/struts-2.5.dtd">
<struts>
	<constant name="struts.enable.DynamicMethodInvocation"
		value="false" />
	<constant name="struts.devMode" value="true" />
	<constant name="struts.objectFactory" value="spring" />

	<package name="default" namespace="/"
		extends="struts-default, json-default">

		<interceptors>
			<interceptor name="authInterceptor"
				class="com.policymanagement.interceptor.AuthInterceptor" />
			<interceptor-stack name="agentStack">
				<interceptor-ref name="defaultStack" />
				<interceptor-ref name="authInterceptor">
					<param name="requiredRole">AGENT</param>
				</interceptor-ref>
			</interceptor-stack>
			<interceptor-stack name="customerStack">
				<interceptor-ref name="defaultStack" />
				<interceptor-ref name="authInterceptor">
					<param name="requiredRole">CUSTOMER</param>
				</interceptor-ref>
			</interceptor-stack>
		</interceptors>

		
		<action name="loginAction" class="loginAction" method="login">
			<result type="json" name="agent">
				<param name="root">jsonResponse</param>
			</result>
			<result type="json" name="customer">
				<param name="root">jsonResponse</param>
			</result>
			<result type="json" name="error">
				<param name="root">jsonResponse</param>
			</result>
			<result type="json" name="input">
				<param name="root">jsonResponse</param>
			</result>
		</action>



		<action name="logout" class="loginAction" method="logout">
			<result name="success" type="redirect">/login.jsp</result>
		</action>

		<action name="registerCustomer" class="registrationAction"
			method="register">
			<result name="success" type="redirect">login.jsp</result>
			<result name="input">register.jsp</result>
			<result name="error">register.jsp</result>
		</action>

		
		<action name="agentDashboard" class="policyAction"
			method="listPolicies">
			<interceptor-ref name="agentStack" />
			<result name="success">/agentDashboard.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

	
		<action name="policyForm" class="policyAction" method="execute">
			<interceptor-ref name="agentStack" />
			<result name="success">/policyForm.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

		
		<action name="addPolicy" class="policyAction"
			method="addPolicy">
			<interceptor-ref name="agentStack" />
			<result name="success" type="redirect">agentDashboard</result>
			<result name="input">/policyForm.jsp</result>
			<result name="error">/policyForm.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

		
		<action name="deletePolicy" class="policyAction"
			method="deletePolicy">
			<interceptor-ref name="agentStack" />
			<result type="json" name="success">
				<param name="root">jsonResponse</param>
			</result>
			<result type="json" name="error">
				<param name="root">jsonResponse</param>
			</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

		<action name="listPolicies" class="policyAction"
			method="listPolicies">
			<interceptor-ref name="agentStack" />
			<result name="success">/policies.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

		
		<action name="getPolicies" class="policyAction"
			method="listPolicies">
			<interceptor-ref name="agentStack" />
			<result type="json" name="success">
				<param name="root">jsonResponse</param>
			</result>
			<result type="json" name="unauthorized">
				<param name="root">jsonResponse</param>
			</result>
		</action>


		
		<action name="customerDashboard" class="policyAction"
			method="listPolicies">
			<interceptor-ref name="customerStack" />
			<result name="success">/customerDashboard.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

		
		<action name="purchasePolicy" class="purchaseAction"
			method="purchase">
			<interceptor-ref name="customerStack" />
			<result name="success" type="redirect">myPolicies</result>
			<result name="input" type="redirect">browsePolicies</result>
			<result name="error">/browsePolicies.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

	
		<action name="myPolicies" class="purchaseAction"
			method="myPolicies">
			<interceptor-ref name="customerStack" />
			<result name="success">/myPolicies.jsp</result>
			<result name="input" type="redirect">browsePolicies</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>
	
		<action name="browsePolicies" class="policyAction"
			method="listPolicies">
			<interceptor-ref name="customerStack" />
			<result name="success">/browsePolicies.jsp</result>
			<result name="unauthorized" type="redirect">/login.jsp</result>
		</action>

	</package>
</struts> 